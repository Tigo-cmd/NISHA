# Root .gitignore for NISHA Sentinel Project

# Dependencies (all languages)
node_modules/
.venv/
venv/
env/
.pio/
.idea/
.vscode/
*.swp
*.swo

# Backend
Backend/.venv/
Backend/__pycache__/
Backend/*.pyc
Backend/*.egg-info/
Backend/.pytest_cache/
Backend/.mypy_cache/
Backend/.coverage
Backend/ai/models/*.pt
Backend/ai/__pycache__/
Backend/migrations/versions/.backup/
Backend/tmp/
Backend/.env

# Frontend
Frontend/.next/
Frontend/out/
Frontend/.vercel/
Frontend/node_modules/
Frontend/.env*
Frontend/*.log
Frontend/coverage/

# Master Node
masters/.venv/
masters/__pycache__/
masters/*.pyc
masters/.pytest_cache/
masters/tmp/
masters/.env
masters/logs/

# Mobile Agent
Nisha-mobile-agent/frontend/node_modules/
Nisha-mobile-agent/frontend/.expo/
Nisha-mobile-agent/frontend/.env
Nisha-mobile-agent/frontend/build/
Nisha-mobile-agent/frontend/dist/
Nisha-mobile-agent/frontend/web-build/
Nisha-mobile-agent/.expo/
Nisha-mobile-agent/.env

# ESP32 Firmware
agents/esp32_s3_agent/.pio/
agents/esp32_s3_agent/build/
agents/esp32_s3_agent/firmware/
agents/esp32_s3_agent/*.bin
agents/esp32_s3_agent/*.hex
agents/esp32_s3_agent/secrets.h
agents/esp32_s3_agent/config_local.h

# AI Models
ai/models/*.pt
ai/models/*.onnx
ai/models/*.pkl
ai/__pycache__/
ai/**/__pycache__/
ai/runs/
ai/output/
ai/train/
ai/val/
ai/test/
ai/logs/
ai/*.json
ai/*.csv
ai/.cache/

# Docker volumes (persisted data)
postgres_data/
redis_data/
minio_data/
grafana_data/

# OS
.DS_Store
Thumbs.db
*.log

# Temporary
tmp/
temp/
*.tmp
*.temp

# Backup files
*.bak
*.backup

# IDE
.vim/
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Environment configs (keep examples only)
.env
.env.*.local
!.env.example

# Credentials / Secrets
credentials.json
service_account.json
*.pem
*.key
*.crt
secrets/
secrets.json

# Uploads generated by system
uploads/
media/
static/uploads/

# Misc
.cache/
.sass-cache/
