# =============================================================================
# NISHA Agent Management System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# Application
APP_NAME=NISHA_SENTINEL
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://nisha:nisha_secret@localhost:5432/nisha_sentinel
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HEARTBEAT_DB=1

# Authentication
API_KEY=change-me-to-a-secure-api-key
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Agent Defaults
HEARTBEAT_INTERVAL_SECONDS=30
HEARTBEAT_TIMEOUT_SECONDS=90
MAX_AGENTS_PER_MASTER=50

# WebSocket
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
